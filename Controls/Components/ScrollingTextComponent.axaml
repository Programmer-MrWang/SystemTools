<ci:ComponentBase
    x:Class="SystemTools.Controls.Components.ScrollingTextComponent"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:local="clr-namespace:SystemTools.Controls.Components"
    xmlns:settings="clr-namespace:SystemTools.Models.ComponentSettings"
    x:TypeArguments="settings:ScrollingTextSettings"
    Loaded="ScrollingTextComponent_OnLoaded"
    Unloaded="ScrollingTextComponent_OnUnloaded">

<ci:ComponentBase.Styles>
        <Style Selector="Rectangle.LedBorder">
            <Setter Property="Stroke" Value="#FF3333" />
            <Setter Property="StrokeThickness" Value="3" />
            <Setter Property="StrokeDashArray" Value="12, 9" />
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="Infinite">
                    <KeyFrame Cue="0%"><Setter Property="StrokeDashOffset" Value="0" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="StrokeDashOffset" Value="21" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </ci:ComponentBase.Styles>

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid x:Name="LayoutRoot" 
              HorizontalAlignment="Center">
            
            <Border Margin="4.5" ClipToBounds="True">
                <Canvas x:Name="TextContainer">
                    <StackPanel x:Name="ScrollingContent" Orientation="Horizontal">
                        <TextBlock x:Name="FirstTextBlock" 
                                   Text="{Binding Settings.TextContent, RelativeSource={RelativeSource AncestorType=local:ScrollingTextComponent}}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#FF3333" />
                        
                        <Canvas x:Name="GapCanvas" Width="100" Height="1" />
                        
                        <TextBlock Text="{Binding Settings.TextContent, RelativeSource={RelativeSource AncestorType=local:ScrollingTextComponent}}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#FF3333" />
                    </StackPanel>
                </Canvas>
            </Border>

            <!-- 联动边框 -->
            <Rectangle Classes="LedBorder"
                       IsVisible="{Binding Settings.ShowBorder, RelativeSource={RelativeSource AncestorType=local:ScrollingTextComponent}}"
                       IsHitTestVisible="False" />

            <!-- LED点阵蒙版 -->
            <Border IsHitTestVisible="True" Opacity="0.2">
                <Border.Background>
                    <VisualBrush DestinationRect="0,0,1,1" TileMode="Tile">
                        <VisualBrush.Visual>
                            <Canvas Width="4" Height="4">
                                <Ellipse Width="2" Height="2"  Canvas.Left="1" Canvas.Top="1" />
                            </Canvas>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.Background>
            </Border>
        </Grid>
    </Grid>
</ci:ComponentBase>
